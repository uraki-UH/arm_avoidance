<?xml version="1.0"?>
<robot name="fuzzbot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:property name="meshes_file_direction" value="package://fuzzbot_description/meshes"/>

  <xacro:arg name="prefix" default=""/>
  <xacro:property name="prefix" value="$(arg prefix)"/>

  <material name="green">
    <color rgba="0.353 1.0 0.098 1.0"/>
  </material>

  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <link name="${prefix}base_footprint"/>

  <joint name="${prefix}base_joint" type="fixed">
    <parent link="${prefix}base_footprint"/>
    <child link="${prefix}base_link"/>
    <origin xyz="0 0 0.059" rpy="0 0 0"/>
  </joint>

  <link name="${prefix}base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${meshes_file_direction}/base.stl" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="-0.0615 0 0.0235" rpy="0 0 0"/>
      <geometry>
        <box size="0.175 0.120 0.155"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="-0.005 0 -0.030" rpy="0 0 0"/>
      <mass value="1.002"/>
      <inertia
        ixx="2.2124416e-03"
        ixy="-1.2294101e-05"
        ixz="3.4938785e-05"
        iyy="2.1193702e-03"
        iyz="-5.0120904e-06"
        izz="2.0064271e-03"/>
    </inertial>
  </link>

  <joint name="${prefix}wheel_left_joint" type="continuous">
    <parent link="${prefix}base_link"/>
    <child link="${prefix}wheel_left_link"/>
    <origin xyz="0.0 0.0745 0.0" rpy="-1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
    <limit velocity="8.063" effort="3.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <link name="${prefix}wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <mesh filename="${meshes_file_direction}/tire.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="green"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.02425" radius="0.06"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.3"/>
      <inertia
        ixx="2.847015625e-04"
        ixy="0.0"
        ixz="0.0"
        iyy="2.847015625e-04"
        iyz="0.0"
        izz="5.400000000e-04"/>
    </inertial>
  </link>

  <joint name="${prefix}wheel_right_joint" type="continuous">
    <parent link="${prefix}base_link"/>
    <child link="${prefix}wheel_right_link"/>
    <origin xyz="0.0 -0.0745 0.0" rpy="1.57079632679 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit velocity="8.063" effort="3.0"/>
    <dynamics damping="0.5" friction="0.0"/>
  </joint>

  <link name="${prefix}wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <mesh filename="${meshes_file_direction}/tire.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="green"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.02425" radius="0.06"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.3"/>
      <inertia
        ixx="2.847015625e-04"
        ixy="0.0"
        ixz="0.0"
        iyy="2.847015625e-04"
        iyz="0.0"
        izz="5.400000000e-04"/>
    </inertial>
  </link>

  <joint name="${prefix}caster_back_right_joint" type="fixed">
    <parent link="${prefix}base_link"/>
    <child link="${prefix}caster_back_right_link"/>
    <origin xyz="-0.131 -0.033 -0.048" rpy="0 0 0"/>
  </joint>

  <link name="${prefix}caster_back_right_link">
    <collision>
      <geometry>
        <sphere radius="0.008"/>
      </geometry>
    </collision>

    <visual>
      <geometry>
        <sphere radius="0.008"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.15"/>
      <inertia
        ixx="3.84e-06"
        ixy="0.0"
        ixz="0.0"
        iyy="3.84e-06"
        iyz="0.0"
        izz="3.84e-06"/>
    </inertial>
  </link>

  <joint name="${prefix}caster_back_left_joint" type="fixed">
    <parent link="${prefix}base_link"/>
    <child link="${prefix}caster_back_left_link"/>
    <origin xyz="-0.131 0.033 -0.048" rpy="0 0 0"/>
  </joint>

  <link name="${prefix}caster_back_left_link">
    <collision>
      <geometry>
        <sphere radius="0.008"/>
      </geometry>
    </collision>

    <visual>
      <geometry>
        <sphere radius="0.008"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.15"/>
      <inertia
        ixx="3.84e-06"
        ixy="0.0"
        ixz="0.0"
        iyy="3.84e-06"
        iyz="0.0"
        izz="3.84e-06"/>
    </inertial>
  </link>

  <joint name="${prefix}battery_joint" type="fixed">
    <parent link="${prefix}base_link"/>
    <child link="${prefix}battery_link"/>
    <origin xyz="-0.097 0 0.018" rpy="0 0 0"/>
  </joint>

  <link name="${prefix}battery_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.666"/>
      <inertia ixx="0.00012342" ixy="0.0" ixz="0.0" iyy="0.00057942" iyz="0.0" izz="0.0006375"/>
    </inertial>
  </link>

  <joint name="${prefix}livox_joint" type="fixed">
    <parent link="${prefix}base_link"/>
    <child link="${prefix}livox_link"/>
    <origin xyz="-0.06425 0 0.1621 " rpy="0 0 0"/>
    <!-- <origin xyz="-0.0492 0 0.1601" rpy="0 0.3927 0"/> -->
  </joint>

  <link name="${prefix}livox_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${meshes_file_direction}/mid360_0.stl" scale="1.0 1.0 1.0"/>
        <!-- <mesh filename="${meshes_file_direction}/mid360_22.5.stl" scale="1.0 1.0 1.0"/> -->
      </geometry>
      <material name="gray"/>
    </visual>

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.265"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <gazebo reference="${prefix}base_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="${prefix}wheel_left_link">
    <material>Gazebo/Green</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>10000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.0001</minDepth>
    <maxVel>0.5</maxVel>
  </gazebo>

  <gazebo reference="${prefix}wheel_right_link">
    <material>Gazebo/Green</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>10000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.0001</minDepth>
    <maxVel>0.5</maxVel>
  </gazebo>

  <gazebo reference="${prefix}caster_back_left_link">
    <material>Gazebo/Grey</material>
    <mu1>0.001</mu1>
    <mu2>0.001</mu2>
    <kp>100000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.5</maxVel>
  </gazebo>

  <gazebo reference="${prefix}caster_back_right_link">
    <material>Gazebo/Grey</material>
    <mu1>0.001</mu1>
    <mu2>0.001</mu2>
    <kp>100000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.5</maxVel>
  </gazebo>

  <gazebo reference="${prefix}livox_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>

      <left_joint>${prefix}wheel_left_joint</left_joint>
      <right_joint>${prefix}wheel_right_joint</right_joint>

      <wheel_separation>0.149</wheel_separation>
      <wheel_diameter>0.12</wheel_diameter>

      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>${prefix}base_footprint</robot_base_frame>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <update_rate>20</update_rate>
    </plugin>
  </gazebo>
</robot>