  <!-- ### TOOL CENTER POINT ### -->
  <joint name="tcp_joint" type="fixed">
    <parent link="tool_link"/>
    <child link="tcp"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
  </joint>
  
  <link name="tcp">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

</robot>
