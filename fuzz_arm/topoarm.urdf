<?xml version="1.0" ?>
<robot name="ToPoArm">

  <!-- Materials for visualization -->
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="yellow_green">
    <color rgba="0.5 1.0 0.0 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>

  <!-- ### BASE ### -->
  <link name="base_link">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="stand_joint" type="fixed">
    <parent link="base_link"/>
    <child link="stand_link"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
  </joint>

  <link name="stand_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.02"/>
      </geometry>
      <material name="yellow_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ### JOINT 1 & LINK 1 ### -->
  <joint name="joint1" type="revolute">
    <parent link="stand_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="100" velocity="1.0"/>
  </joint>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0.04125" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.0825"/>
      </geometry>
      <material name="yellow_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04125" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.0825"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <origin xyz="0 0 0.04125" rpy="0 0 0"/>
      <inertia ixx="0.000164" ixy="0" ixz="0" iyy="0.000164" iyz="0" izz="0.000069"/>
    </inertial>
  </link>

  <!-- ### JOINT 2 & LINK 2 ### -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.0825" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="100" velocity="1.0"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0.06175" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.1235"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.06175" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.1235"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <origin xyz="0 0 0.06175" rpy="0 0 0"/>
      <inertia ixx="0.000280" ixy="0" ixz="0" iyy="0.000280" iyz="0" izz="0.000069"/>
    </inertial>
  </link>

  <!-- ### JOINT 3 & LINK 3 ### -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.1235" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="100" velocity="1.0"/>
  </joint>

  <link name="link3">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.06"/>
      </geometry>
      <material name="yellow_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00004"/>
    </inertial>
  </link>

  <!-- ### JOINT 4 & LINK 4 (Virtual) ### -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="50" velocity="1.5"/>
  </joint>

  <link name="link4">
    <visual>
      <origin xyz="0 0 0.02225" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.0445"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02225" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.0445"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0.02225" rpy="0 0 0"/>
      <inertia ixx="0.00006" ixy="0" ixz="0" iyy="0.00006" iyz="0" izz="0.00002"/>
    </inertial>
  </link>

  <!-- ### JOINT 5 & LINK 5 (Wrist) ### -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0.0445" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="50" velocity="1.5"/>
  </joint>

  <link name="link5">
    <visual>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.09"/>
      </geometry>
      <material name="yellow_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.09"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <inertia ixx="0.00015" ixy="0" ixz="0" iyy="0.00015" iyz="0" izz="0.00006"/>
    </inertial>
  </link>

  <!-- ### JOINT 6 & TOOL LINK (Gripper) ### -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="tool_link"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="50" velocity="1.5"/>
  </joint>

  <link name="tool_link">
    <visual>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.09"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.09"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <inertia ixx="0.00015" ixy="0" ixz="0" iyy="0.00015" iyz="0" izz="0.00006"/>
    </inertial>
  </link>

  <!-- ### GRIPPER FINGERS ### -->
  <!-- <joint name="left_finger_joint" type="prismatic">
    <parent link="tool_link"/>
    <child link="left_finger"/>
    <origin xyz="0 0.025 0.09" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.02" upper="0.0" effort="20" velocity="0.1"/>
  </joint> -->
